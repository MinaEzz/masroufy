// ============================================================
// prisma/schema.prisma
// مصروفي (Masroufy) - Database Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
}

// ============================================================
// ENUMS
// ============================================================

/// نوع الحساب/المحفظة
enum AccountType {
  CASH
  DEBIT
  CREDIT
  VODAFONE_CASH
  OTHER
}

/// نوع العملية المالية
enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

// ============================================================
// NEXTAUTH MODELS (Required by @auth/prisma-adapter)
// ============================================================

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // hashed with bcryptjs (for credentials provider)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts      Account[]        @relation("UserAccounts")
  transactions  Transaction[]
  categories    Category[]
  sessions      Session[]
  authAccounts  AuthAccount[]

  @@map("users")
}

model AuthAccount {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("auth_accounts")
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================
// CORE BUSINESS MODELS
// ============================================================

/// المحفظة/الحساب المالي
/// يدعم تخصيص الاسم الكامل (مثل: بنك مصر - فيزا) مع تحديد النوع
model Account {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  userId      String      @db.ObjectId
  /// الاسم المخصص من المستخدم (مثل: "بنك مصر ديبت" أو "كاش روتيني")
  name        String
  /// نوع المحفظة (CASH, DEBIT, CREDIT, ...)
  type        AccountType
  /// الرصيد الحالي — يُحدَّث تلقائياً عبر Prisma Transactions
  balance     Float       @default(0)
  /// العملة (افتراضي: EGP)
  currency    String      @default("EGP")
  /// لون مخصص (اختياري) لتمييز الحساب في الواجهة
  color       String?
  /// أيقونة مخصصة للحساب
  icon        String?
  /// رصيد الحد الائتماني (لبطاقات الائتمان فقط)
  creditLimit Float?
  isArchived  Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  user                 User          @relation("UserAccounts", fields: [userId], references: [id], onDelete: Cascade)
  outgoingTransactions Transaction[] @relation("FromAccount")
  incomingTransactions Transaction[] @relation("ToAccount")

  @@index([userId])
  @@map("accounts")
}

/// التصنيفات المالية (قابلة للتخصيص من المستخدم)
model Category {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  /// اسم التصنيف (مثل: أكل، مواصلات، إيجار)
  name      String
  /// مفتاح الترجمة i18n (مثل: categories.food)
  i18nKey   String?
  /// أيقونة التصنيف (Lucide icon name)
  icon      String?
  /// لون التصنيف في الرسوم البيانية
  color     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([userId, name])
  @@index([userId])
  @@map("categories")
}

/// سجل العمليات المالية
model Transaction {
  id          String          @id @default(auto()) @map("_id") @db.ObjectId
  userId      String          @db.ObjectId
  accountId   String          @db.ObjectId /// حساب المصدر دائماً
  toAccountId String?         @db.ObjectId /// حساب الوجهة (التحويلات فقط)
  categoryId  String?         @db.ObjectId
  type        TransactionType
  amount      Float
  /// الملاحظة أو الوصف المخصص
  note        String?
  /// تاريخ تأكيد أو إتمام العملية (قد يختلف عن createdAt)
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  account     Account   @relation("FromAccount", fields: [accountId], references: [id])
  toAccount   Account?  @relation("ToAccount", fields: [toAccountId], references: [id])
  category    Category? @relation(fields: [categoryId], references: [id])

  @@index([userId])
  @@index([userId, date])
  @@index([accountId])
  @@map("transactions")
}
